local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "ProHUD"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

-- ===== TẠO BAR =====
local function createBar(yPos, color)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 250, 0, 20)
    frame.Position = UDim2.new(0, 10, 0, yPos)
    frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
    frame.BorderSizePixel = 0
    frame.Parent = gui

    local corner = Instance.new("UICorner", frame)
    corner.CornerRadius = UDim.new(0, 6)

    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(1, 0, 1, 0)
    bar.BackgroundColor3 = color
    bar.BorderSizePixel = 0
    bar.Parent = frame

    local barCorner = Instance.new("UICorner", bar)
    barCorner.CornerRadius = UDim.new(0, 6)

    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1,0,1,0)
    text.BackgroundTransparency = 1
    text.TextColor3 = Color3.fromRGB(255,255,255)
    text.TextScaled = true
    text.Font = Enum.Font.SourceSansBold
    text.Parent = frame

    return bar, text
end

-- Tạo 2 thanh
local hpBar, hpText = createBar(10, Color3.fromRGB(0,255,0))
local enBar, enText = createBar(40, Color3.fromRGB(0,150,255))

-- ===== SETUP =====
local function setup(char)
    local humanoid = char:WaitForChild("Humanoid")

    -- cố tìm energy thật
    local energy = player:FindFirstChild("Energy")
    local maxEnergy = player:FindFirstChild("MaxEnergy")

    local function update()
        -- HP
        local hp = humanoid.Health
        local maxHp = humanoid.MaxHealth
        local hpPercent = hp / maxHp

        hpBar.Size = UDim2.new(hpPercent,0,1,0)
        hpText.Text = math.floor(hp).." / "..math.floor(maxHp)

        if hpPercent > 0.6 then
            hpBar.BackgroundColor3 = Color3.fromRGB(0,255,0)
        elseif hpPercent > 0.3 then
            hpBar.BackgroundColor3 = Color3.fromRGB(255,170,0)
        else
            hpBar.BackgroundColor3 = Color3.fromRGB(255,0,0)
        end

        -- ENERGY
        if energy and maxEnergy then
            local en = energy.Value
            local maxEn = maxEnergy.Value
            local percent = en / maxEn

            enBar.Size = UDim2.new(percent,0,1,0)
            enText.Text = math.floor(en).." / "..math.floor(maxEn)
        else
            -- fallback nếu không đọc được
            enBar.Size = UDim2.new(1,0,1,0)
            enText.Text = "ENERGY ?"
        end
    end

    update()
    humanoid.HealthChanged:Connect(update)

    if energy then
        energy:GetPropertyChangedSignal("Value"):Connect(update)
    end
end

if player.Character then
    setup(player.Character)
end

player.CharacterAdded:Connect(setup)
