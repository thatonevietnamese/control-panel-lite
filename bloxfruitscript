-- ===== ENERGY FIND =====
local energyLabel

local function findEnergyLabel()
    local gui = player:FindFirstChild("PlayerGui")
    if not gui then return end

    local main = gui:FindFirstChild("Main")
    if not main then return end

    local energy = main:FindFirstChild("Energy")
    if not energy then return end

    return energy:FindFirstChild("TextLabel")
end

local function getEnergy()
    if not energyLabel then return end
    local text = energyLabel.Text
    local current, max = string.match(text, "(%d+)%s*/%s*(%d+)")
    return tonumber(current), tonumber(max)
end

-- ===== SETUP =====
local function setup(char)
    local humanoid = char:FindFirstChild("Humanoid") or char:WaitForChild("Humanoid", 5)
    if not humanoid then return end

    -- tìm energy async
    energyLabel = nil
    task.spawn(function()
        while not energyLabel do
            local ok, result = pcall(findEnergyLabel)
            if ok and result and result:IsA("TextLabel") then
                energyLabel = result
            end
            task.wait(0.5)
        end
    end)

    local function update()
        -- HP
        if humanoid and humanoid.Parent and hpBar then
            local hp = humanoid.Health or 0
            local maxHp = humanoid.MaxHealth or 1
            local hpPercent = hp / maxHp

            hpBar.Size = UDim2.new(hpPercent,0,1,0)
            hpText.Text = math.floor(hp).." / "..math.floor(maxHp)

            if hpPercent > 0.6 then
                hpBar.BackgroundColor3 = Color3.fromRGB(0,255,0)
            elseif hpPercent > 0.3 then
                hpBar.BackgroundColor3 = Color3.fromRGB(255,170,0)
            else
                hpBar.BackgroundColor3 = Color3.fromRGB(255,0,0)
            end
        end

        -- ENERGY
        if enBar and enText then
            if energyLabel then
                local ok, en, maxEn = pcall(getEnergy)
                if ok and en and maxEn then
                    local percent = en / maxEn
                    enBar.Size = UDim2.new(percent,0,1,0)
                    enText.Text = en.." / "..maxEn
                else
                    enText.Text = "..."
                end
            else
                enText.Text = "..."
            end
        end
    end

    -- LOOP UPDATE (KHÔNG BAO GIỜ CHẾT)
    task.spawn(function()
        while char.Parent do
            pcall(update)
            task.wait(0.2)
        end
    end)

    humanoid.HealthChanged:Connect(function()
        pcall(update)
    end)

    task.spawn(function()
        repeat task.wait() until energyLabel
        if energyLabel then
            energyLabel:GetPropertyChangedSignal("Text"):Connect(function()
                pcall(update)
            end)
        end
    end)
end

