-- ===== TẠO BAR =====
local function createBar(yPos, color)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 250, 0, 20)
    frame.Position = UDim2.new(0, 10, 0, yPos)
    frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
    frame.BorderSizePixel = 0
    frame.Parent = gui

    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)

    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(1, 0, 1, 0)
    bar.BackgroundColor3 = color
    bar.BorderSizePixel = 0
    bar.Parent = frame

    Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 6)

    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1,0,1,0)
    text.BackgroundTransparency = 1
    text.TextColor3 = Color3.fromRGB(255,255,255)
    text.TextScaled = true
    text.Font = Enum.Font.SourceSansBold
    text.Parent = frame

    return bar, text
end

-- ===== UI =====
local hpBar, hpText = createBar(10, Color3.fromRGB(0,255,0))
local enBar, enText = createBar(40, Color3.fromRGB(0,150,255))

-- ===== ENERGY HOOK =====
local energyLabel

local function findEnergyLabel()
    local gui = player:WaitForChild("PlayerGui")
    local main = gui:FindFirstChild("Main")
    if main then
        local energy = main:FindFirstChild("Energy")
        if energy then
            return energy:FindFirstChild("TextLabel")
        end
    end
end

local function getEnergy()
    if not energyLabel then return end
    local text = energyLabel.Text
    local current, max = string.match(text, "(%d+)%s*/%s*(%d+)")
    return tonumber(current), tonumber(max)
end

-- ===== SETUP =====
local function setup(char)
    local humanoid = char:WaitForChild("Humanoid")

    -- tìm lại energy mỗi lần respawn
    energyLabel = nil
    repeat
        energyLabel = findEnergyLabel()
        task.wait(0.5)
    until energyLabel

    local function update()
        -- HP
        local hp = humanoid.Health
        local maxHp = humanoid.MaxHealth
        local hpPercent = hp / maxHp

        hpBar.Size = UDim2.new(hpPercent,0,1,0)
        hpText.Text = math.floor(hp).." / "..math.floor(maxHp)

        if hpPercent > 0.6 then
            hpBar.BackgroundColor3 = Color3.fromRGB(0,255,0)
        elseif hpPercent > 0.3 then
            hpBar.BackgroundColor3 = Color3.fromRGB(255,170,0)
        else
            hpBar.BackgroundColor3 = Color3.fromRGB(255,0,0)
        end

        -- ENERGY
        local en, maxEn = getEnergy()
        if en and maxEn then
            local percent = en / maxEn
            enBar.Size = UDim2.new(percent,0,1,0)
            enText.Text = en.." / "..maxEn
        else
            enText.Text = "Loading..."
        end
    end

    update()
    humanoid.HealthChanged:Connect(update)

    energyLabel:GetPropertyChangedSignal("Text"):Connect(update)
end

-- ===== RUN =====
if player.Character then
    setup(player.Character)
end

player.CharacterAdded:Connect(setup)
