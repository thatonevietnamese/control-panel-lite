-- ===== CREATE BAR =====
local function createBar(name, yPos, color)
    local frame = Instance.new("Frame")
    frame.Name = name
    frame.Size = UDim2.new(0, 250, 0, 20)
    frame.Position = UDim2.new(0, 10, 0, yPos)
    frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
    frame.BorderSizePixel = 0
    frame.Parent = gui

    local bar = Instance.new("Frame")
    bar.Name = "BAR"
    bar.Size = UDim2.new(1,0,1,0)
    bar.BackgroundColor3 = color
    bar.BorderSizePixel = 0
    bar.Parent = frame

    local text = Instance.new("TextLabel")
    text.Name = "TEXT"
    text.Size = UDim2.new(1,0,1,0)
    text.BackgroundTransparency = 1
    text.TextColor3 = Color3.fromRGB(255,255,255)
    text.TextScaled = true
    text.Parent = frame

    return bar, text
end

-- ===== CREATE 2 BAR DUY NHẤT =====
local hpBar, hpText = createBar("HP_BAR", 10, Color3.fromRGB(0,255,0))
local enBar, enText = createBar("EN_BAR", 40, Color3.fromRGB(0,150,255))

-- ===== ENERGY FIND =====
local function findEnergyLabel()
    local gui = player:FindFirstChild("PlayerGui")
    if not gui then return end

    local main = gui:FindFirstChild("Main")
    if not main then return end

    local energy = main:FindFirstChild("Energy")
    if not energy then return end

    return energy:FindFirstChild("TextLabel")
end

local energyLabel

task.spawn(function()
    while not energyLabel do
        local ok, result = pcall(findEnergyLabel)
        if ok and result then
            energyLabel = result
        end
        task.wait(0.5)
    end
end)

local function getEnergy()
    if not energyLabel then return end
    local current, max = string.match(energyLabel.Text, "(%d+)%s*/%s*(%d+)")
    return tonumber(current), tonumber(max)
end

-- ===== UPDATE LOOP =====
local function start(char)
    local humanoid = char:WaitForChild("Humanoid")

    task.spawn(function()
        while char.Parent do
            -- HP
            local hp = humanoid.Health
            local maxHp = humanoid.MaxHealth
            local hpPercent = hp / maxHp

            hpBar.Size = UDim2.new(hpPercent,0,1,0)
            hpText.Text = math.floor(hp).." / "..math.floor(maxHp)

            -- ENERGY
            if energyLabel then
                local en, maxEn = getEnergy()
                if en and maxEn then
                    local percent = en / maxEn
                    enBar.Size = UDim2.new(percent,0,1,0)
                    enText.Text = en.." / "..maxEn
                end
            end

            task.wait(0.2)
        end
    end)
end

-- ===== RUN =====
if player.Character then
    start(player.Character)
end

player.CharacterAdded:Connect(start)
