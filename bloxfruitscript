-- ===== SAFE ENERGY =====
local function getEnergySafe()
    if not energyLabel or not energyLabel.Text then
        return 0, 100
    end

    local current, max = string.match(energyLabel.Text, "(%d+)%s*/%s*(%d+)")
    current = tonumber(current)
    max = tonumber(max)

    if not current or not max or max == 0 then
        return 0, 100
    end

    return current, max
end

-- ===== START =====
local function start(char)
    local humanoid = char:WaitForChild("Humanoid",5)
    if not humanoid then return end

    task.spawn(function()
        while char.Parent do
            -- ===== HP =====
            local hp = humanoid.Health or 0
            local maxHp = humanoid.MaxHealth or 100
            local hpPercent = math.clamp(hp / maxHp, 0, 1)

            hpBar.Size = UDim2.new(hpPercent,0,1,0)
            hpText.Text = math.floor(hp).." / "..math.floor(maxHp)
            hpBar.Visible = true

            -- đổi màu cho đẹp 😈
            if hpPercent > 0.6 then
                hpBar.BackgroundColor3 = Color3.fromRGB(0,255,0)
            elseif hpPercent > 0.3 then
                hpBar.BackgroundColor3 = Color3.fromRGB(255,170,0)
            else
                hpBar.BackgroundColor3 = Color3.fromRGB(255,0,0)
            end

            -- ===== ENERGY =====
            local en, maxEn = getEnergySafe()
            local percent = math.clamp(en / maxEn, 0, 1)

            enBar.Size = UDim2.new(percent,0,1,0)
            enText.Text = math.floor(en).." / "..math.floor(maxEn)
            enBar.Visible = true

            task.wait(0.2)
        end
    end)
end

-- ===== RUN =====
if player.Character then
    start(player.Character)
end

player.CharacterAdded:Connect(start)
